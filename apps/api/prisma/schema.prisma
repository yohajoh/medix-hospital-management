
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING
}

enum QRType {
  LOGIN
  CHECKIN
  PRESCRIPTION
  DOCUMENT_ACCESS
}

enum OTPPurpose {
  LOGIN
  PASSWORD_RESET
  PHONE_VERIFICATION
  APPOINTMENT_CONFIRMATION
  TRANSACTION_AUTHORIZATION
}

// --- MODELS ---

model User {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  password           String?    
  phone              String?    @unique
  
  // OAuth & Integration
  googleId           String?    @unique
  googleRefreshToken String?    
  calendarConnected  Boolean    @default(false)

  role               UserRole   @default(PATIENT)
  status             UserStatus @default(ACTIVE)

  // Relations
  qrCodes            QRCode[]
  notifications      Notification[]

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt 

  @@map("users") 
}

model QRCode {
  id           String    @id @default(uuid())
  // The unique session ID used for the Socket.io room
  sessionId    String    @unique
  
  // The user who scanned/authorized the code
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         QRType    @default(LOGIN)
  
  // Handshake State
  isUsed       Boolean   @default(false)
  isApproved   Boolean   @default(false)
  
  // Metadata for security
  deviceInfo   String?   
  ipAddress    String?

  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([sessionId])
  @@map("qr_codes")
}

model VerificationToken {
  id        String     @id @default(uuid())
  target    String     // Email or Phone
  token     String     // The OTP code
  purpose   OTPPurpose @default(LOGIN)
  metadata  Json?      // Flexible storage for temporary data
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@unique([target, purpose]) // One active OTP per target per purpose
  @@index([target])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  type      String   
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}